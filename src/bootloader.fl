// ============================================================================
// Tests (80 lines)
// ============================================================================

mod tests {
    use super::*;

    #[test]
    fn test_cpu_state_creation() {
        let cpu = ARM64CPUState::new();
        assert_eq!(cpu.pc, 0x80000000);
        assert_eq!(cpu.el, 3);
    }

    #[test]
    fn test_cpu_mode_el3() {
        let cpu = ARM64CPUState::new();
        match cpu.get_cpu_mode() {
            CPUMode::EL3 => {},
            _ => panic!("Expected EL3"),
        }
    }

    #[test]
    fn test_mmu_enable_disable() {
        let mut cpu = ARM64CPUState::new();
        assert!(!cpu.is_mmu_enabled());
        cpu.enable_mmu();
        assert!(cpu.is_mmu_enabled());
        cpu.disable_mmu();
        assert!(!cpu.is_mmu_enabled());
    }

    #[test]
    fn test_boot_sequence_stage1() {
        let mut boot = BootSequence::new();
        assert!(boot.stage1_init().is_ok());
        assert!(boot.memory_initialized);
    }

    #[test]
    fn test_boot_sequence_stage2() {
        let mut boot = BootSequence::new();
        boot.stage1_init().unwrap();
        assert!(boot.stage2_transition().is_ok());
        assert_eq!(boot.cpu_state.el, 1);
    }

    #[test]
    fn test_boot_sequence_stage3() {
        let mut boot = BootSequence::new();
        boot.stage1_init().unwrap();
        boot.stage2_transition().unwrap();
        assert!(boot.stage3_kernel_init().is_ok());
        assert!(boot.boot_complete());
    }

    #[test]
    fn test_memory_layout_validation() {
        let layout = MemoryLayout::new();
        assert!(layout.validate().is_ok());
    }

    #[test]
    fn test_memory_layout_kernel_ptr() {
        let layout = MemoryLayout::new();
        let ptr = layout.get_kernel_ptr();
        assert_eq!(ptr.address, 0x80000000);
        assert_eq!(ptr.size_bytes, 0x200000);
    }

    #[test]
    fn test_uart_initialization() {
        let uart = UART::new(0xFF800000);
        assert!(uart.init().is_ok());
    }

    #[test]
    fn test_clock_manager_creation() {
        let clk = ClockManager::new(0xFF800000);
        assert_eq!(clk.get_system_clock_mhz(), 800);
    }
}
