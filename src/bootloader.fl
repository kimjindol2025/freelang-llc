// ============================================================================
// Part 4: Memory Layout Initialization (130 lines)
// ============================================================================

pub struct MemoryLayout {
    pub kernel_base: u64,       // 0x80000000
    pub kernel_size: u64,       // 2MB
    pub page_table_base: u64,   // 0x80000000
    pub stack_base: u64,        // 0x80200000
    pub heap_base: u64,         // 0x80300000
    pub device_base: u64,       // 0xFF800000 (device memory)
    pub uart_base: u64,         // 0xFF800000 (UART device)
}

impl MemoryLayout {
    pub fn new() -> Self {
        MemoryLayout {
            kernel_base: 0x80000000,
            kernel_size: 0x200000,        // 2MB
            page_table_base: 0x80000000,
            stack_base: 0x80200000,
            heap_base: 0x80300000,
            device_base: 0xFF800000,
            uart_base: 0xFF800000,
        }
    }

    pub fn validate(&self) -> Result<(), String> {
        // Check memory layout consistency
        if self.kernel_base >= self.stack_base {
            return Err("Kernel overlaps stack".to_string());
        }
        if self.stack_base >= self.heap_base {
            return Err("Stack overlaps heap".to_string());
        }
        if self.heap_base >= self.device_base {
            return Err("Heap overlaps device memory".to_string());
        }
        Ok(())
    }

    pub fn get_kernel_ptr(&self) -> ManagedPointer {
        ManagedPointer::new(
            self.kernel_base,
            self.kernel_size,
            "u64".to_string()
        )
    }

    pub fn get_stack_ptr(&self) -> ManagedPointer {
        ManagedPointer::new(
            self.stack_base,
            0x100000,  // 1MB stack
            "u64".to_string()
        )
    }

    pub fn get_uart_ptr(&self) -> ManagedPointer {
        // UART registers at 0xFF800000 (volatile MMIO)
        ManagedPointer::new_volatile(
            self.uart_base,
            0x1000,  // UART register space
            "u32".to_string()
        )
    }
}

